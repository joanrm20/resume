---
import { resume, locationString, yearsSince } from '../lib/resume'

const b = resume.basics
const years = yearsSince(resume.work[resume.work.length - 1].startDate)
const loc = locationString(b.location)
const focus = ['frontend architecture', 'design systems', 'developer experience']
---

<header class="hero wrap">
  <p class="termline mono" aria-hidden="true">
    <span class="user">jose@joanrm20</span><span class="punct">:</span><span class="path">~</span><span class="punct">$</span> whoami<span class="cursor"></span>
  </p>

  <h1 class="name">{b.name}</h1>
  <p class="role">{b.label}</p>

  <p class="tagline mono">
    {years}+ years<span class="dot">·</span>{loc}<span class="dot">·</span>{focus.join(' · ')}
  </p>

  {b.summary && <p class="summary">{b.summary}</p>}

  <nav class="links mono" aria-label="Profiles and résumé">
    {b.profiles?.map((p) => (
      <a href={p.url} target="_blank" rel="noopener">{p.network.toLowerCase()}</a>
    ))}
    <a href="/jose_ramirez_cv.pdf">pdf</a>
    {b.email && <a href={`mailto:${b.email}`}>email</a>}
  </nav>
</header>

<style>
  .hero {
    padding-top: clamp(3rem, 2rem + 6vw, 6.5rem);
    padding-bottom: clamp(2rem, 1.5rem + 3vw, 3.5rem);
  }
  .termline {
    font-size: var(--step--1);
    color: var(--fg-soft);
    margin-bottom: 1.4rem;
  }
  .user { color: var(--accent); }
  .punct { color: var(--fg-faint); }
  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1.05em;
    margin-left: 0.15em;
    background: var(--accent);
    vertical-align: -0.18em;
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .cursor { animation: none; } }

  .name {
    font-size: var(--step-4);
    font-weight: 500;
    letter-spacing: -0.03em;
  }
  .role {
    font-family: var(--font-display);
    font-size: var(--step-2);
    color: var(--fg-soft);
    font-weight: 380;
    font-style: italic;
    margin-top: 0.1rem;
  }
  .tagline {
    font-size: var(--step--1);
    color: var(--fg-soft);
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.5rem;
  }
  .dot { color: var(--accent); margin-inline: 0.35rem; }
  .summary {
    max-width: var(--measure);
    font-size: var(--step-1);
    line-height: 1.5;
    margin-top: 1.6rem;
    color: var(--fg);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem;
    margin-top: 1.8rem;
    font-size: var(--step--1);
  }
  .links a {
    color: var(--fg-soft);
    text-decoration: none;
    position: relative;
  }
  .links a::before { content: '→ '; color: var(--accent); }
  .links a:hover { color: var(--fg); }
</style>
