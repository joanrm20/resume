---
interface Props {
  n: string
  title: string
  id?: string
}
const { n, title, id } = Astro.props
---

<section class="section" id={id}>
  <div class="wrap">
    <div class="section-head reveal">
      <span class="idx mono">{n}</span>
      <h2>{title}</h2>
    </div>
    <slot />
  </div>
</section>

<style>
  .idx {
    color: var(--accent);
    font-size: var(--step--1);
    align-self: center;
  }
</style>
