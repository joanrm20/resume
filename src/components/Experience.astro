---
import { resume, dateRange } from '../lib/resume'
---

<ol class="timeline">
  {resume.work.map((job) => (
    <li class="entry reveal">
      <div class="node" aria-hidden="true"></div>
      <div class="head">
        <h3 class="position">{job.position}</h3>
        <span class="dates mono">{dateRange(job.startDate, job.endDate)}</span>
      </div>
      <p class="org mono">
        {job.url ? <a href={job.url} target="_blank" rel="noopener">{job.name}</a> : job.name}
        {job.location && <span class="loc"> · {job.location}</span>}
      </p>
      {job.description && <p class="desc">{job.description}</p>}
      {job.highlights?.length ? (
        <ul class="highlights">
          {job.highlights.map((h) => <li>{h}</li>)}
        </ul>
      ) : null}
    </li>
  ))}
</ol>

<style>
  .timeline { list-style: none; }
  .entry {
    position: relative;
    padding-left: 1.5rem;
    padding-bottom: 2.2rem;
  }
  .entry:not(:last-child) {
    border-left: 1px solid var(--line);
    margin-left: 4px;
    padding-left: calc(1.5rem - 4px);
  }
  .node {
    position: absolute;
    left: -4.5px;
    top: 0.55rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
  }
  .head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.25rem 1rem;
  }
  .position { font-size: var(--step-1); font-weight: 480; }
  .dates { font-size: var(--step--1); color: var(--fg-faint); white-space: nowrap; }
  .org {
    font-size: var(--step--1);
    color: var(--accent);
    margin-top: 0.15rem;
  }
  .org a { text-decoration: none; }
  .org a:hover { text-decoration: underline; }
  .loc { color: var(--fg-faint); }
  .desc { color: var(--fg-soft); margin-top: 0.6rem; max-width: var(--measure); }
  .highlights {
    margin-top: 1.1rem;
    max-width: var(--measure);
    display: grid;
    gap: 0.85rem;
    list-style: none;
  }
  .highlights li { position: relative; padding-left: 1.15rem; line-height: 1.6; }
  .highlights li::before {
    content: '';
    position: absolute;
    left: 0.05rem;
    top: 0.62em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }
</style>
