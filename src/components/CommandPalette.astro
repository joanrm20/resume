---
import { resume } from '../lib/resume'

const b = resume.basics
const profiles = (b.profiles ?? []).map((p) => ({ label: p.network, url: p.url }))
const email = b.email ?? ''
---

<button id="cmdk-trigger" class="cmdk-trigger mono" aria-label="Open command menu" aria-keyshortcuts="Meta+K Control+K">
  <kbd>⌘</kbd><kbd>K</kbd>
</button>

<div id="cmdk" class="cmdk" hidden>
  <div class="cmdk-overlay" data-cmdk-close></div>
  <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Command menu">
    <input
      id="cmdk-input"
      class="cmdk-input mono"
      type="text"
      placeholder="Type a command…"
      aria-label="Type a command or search"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
    />
    <ul id="cmdk-list" class="cmdk-list" role="listbox" aria-label="Commands"></ul>
  </div>
</div>

<script define:vars={{ profiles, email }}>
  const $ = (id) => document.getElementById(id)

  const go = (url) => { closeCmdk(); window.location.href = url }
  const toggleTheme = () => {
    const el = document.documentElement
    const cur = el.getAttribute('data-theme') ||
      (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
    const next = cur === 'dark' ? 'light' : 'dark'
    el.setAttribute('data-theme', next)
    try { localStorage.setItem('theme', next) } catch {}
  }
  const openLink = (url) => window.open(url, '_blank', 'noopener')
  const copyEmail = async () => { try { await navigator.clipboard.writeText(email) } catch {} }

  const commands = [
    { label: 'Home', hint: 'page', run: () => go('/') },
    { label: 'Experience', hint: 'page', run: () => go('/experience') },
    { label: 'Writing', hint: 'page', run: () => go('/blog') }, // comment out while drafting
    { label: 'Skills', hint: 'experience', run: () => go('/experience#skills') },
    { label: 'Projects', hint: 'experience', run: () => go('/experience#projects') },
    { label: 'Education', hint: 'experience', run: () => go('/experience#education') },
    { label: 'Toggle theme', hint: 'light / dark', run: toggleTheme },
    ...(email ? [{ label: 'Copy email', hint: email, run: copyEmail }] : []),
    ...profiles.map((p) => ({ label: `Open ${p.label}`, hint: 'link', run: () => openLink(p.url) })),
    { label: 'Download résumé', hint: 'pdf', run: () => go('/jose_ramirez_cv.pdf') },
  ]

  let active = 0
  let filtered = commands

  function render() {
    const list = $('cmdk-list'); if (!list) return
    list.innerHTML = ''
    filtered.forEach((cmd, i) => {
      const li = document.createElement('li')
      li.className = 'cmdk-item' + (i === active ? ' is-active' : '')
      li.setAttribute('role', 'option')
      li.setAttribute('aria-selected', String(i === active))
      li.innerHTML = `<span class="cmdk-label"></span><span class="cmdk-hint mono"></span>`
      li.querySelector('.cmdk-label').textContent = cmd.label
      li.querySelector('.cmdk-hint').textContent = cmd.hint
      li.addEventListener('click', () => runCmd(i))
      li.addEventListener('mousemove', () => { if (active !== i) { active = i; paint() } })
      list.appendChild(li)
    })
  }
  function paint() {
    const list = $('cmdk-list'); if (!list) return
    ;[...list.children].forEach((li, i) => {
      const on = i === active
      li.classList.toggle('is-active', on)
      li.setAttribute('aria-selected', String(on))
      if (on) li.scrollIntoView({ block: 'nearest' })
    })
  }
  function filterCmds() {
    const input = $('cmdk-input'); if (!input) return
    const q = input.value.trim().toLowerCase()
    filtered = q ? commands.filter((c) => (c.label + ' ' + c.hint).toLowerCase().includes(q)) : commands
    active = 0
    render()
  }
  function runCmd(i) {
    const cmd = filtered[i]
    if (cmd) { cmd.run(); if (cmd.label !== 'Toggle theme') closeCmdk() }
  }
  function openCmdk() {
    const root = $('cmdk'), input = $('cmdk-input'); if (!root) return
    root.hidden = false
    if (input) input.value = ''
    filterCmds()
    requestAnimationFrame(() => input && input.focus())
  }
  function closeCmdk() { const root = $('cmdk'); if (root) root.hidden = true }
  function isOpen() { const root = $('cmdk'); return !!root && !root.hidden }

  // Global shortcut — bound once, queries the DOM fresh so it survives view transitions.
  if (!window.__cmdkKeys) {
    window.__cmdkKeys = true
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault()
        isOpen() ? closeCmdk() : openCmdk()
      } else if (e.key === 'Escape' && isOpen()) {
        closeCmdk()
      }
    })
  }

  // Per-page wiring — re-runs after each navigation; the current panel wires once.
  function wireCmdk() {
    const root = $('cmdk'), input = $('cmdk-input')
    if (!root || !input || root.dataset.wired) return
    root.dataset.wired = '1'
    input.addEventListener('input', filterCmds)
    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); active = Math.min(active + 1, filtered.length - 1); paint() }
      else if (e.key === 'ArrowUp') { e.preventDefault(); active = Math.max(active - 1, 0); paint() }
      else if (e.key === 'Enter') { e.preventDefault(); runCmd(active) }
    })
    root.querySelector('[data-cmdk-close]')?.addEventListener('click', closeCmdk)
    $('cmdk-trigger')?.addEventListener('click', openCmdk)
  }
  document.addEventListener('astro:page-load', wireCmdk)
  wireCmdk()
</script>

<style is:global>
  .cmdk[hidden] { display: none; }

  .cmdk-trigger {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    display: inline-flex;
    gap: 0.25rem;
    align-items: center;
    padding: 0.55rem 0.7rem;
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    border-radius: 8px;
    color: var(--accent);
    font-weight: 500;
    cursor: pointer;
    box-shadow: var(--shadow);
  }
  .cmdk-trigger:hover { background: var(--accent); color: var(--bg); }
  .cmdk-trigger kbd {
    font: inherit;
    font-size: var(--step--1);
    line-height: 1;
  }

  .cmdk {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    align-items: start;
    justify-items: center;
    padding-top: 14vh;
  }
  .cmdk-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--bg) 55%, transparent);
    backdrop-filter: blur(3px);
  }
  .cmdk-panel {
    position: relative;
    width: min(540px, 92vw);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .cmdk-input {
    width: 100%;
    padding: 1rem 1.1rem;
    border: 0;
    border-bottom: 1px solid var(--line);
    background: transparent;
    color: var(--fg);
    font-size: var(--step-0);
    outline: none;
  }
  .cmdk-list { list-style: none; max-height: 320px; overflow-y: auto; padding: 0.4rem; }
  .cmdk-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
  }
  .cmdk-item.is-active { background: var(--accent-soft); }
  .cmdk-item.is-active .cmdk-label { color: var(--accent); }
  .cmdk-hint { font-size: var(--step--1); color: var(--fg-faint); }
</style>
