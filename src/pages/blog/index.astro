---
import Base from '../../layouts/Base.astro'
import { getCollection } from 'astro:content'
import { resume } from '../../lib/resume'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
)

const fmt = (d: Date) =>
  d.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })
---

<Base title={`Writing — ${resume.basics.name}`} description="Posts and notes on frontend, design systems, and developer experience.">
  <main class="wrap">
    <header class="page-head">
      <a href="/" class="back mono">← home</a>
      <h1>Writing</h1>
    </header>

    {posts.length > 0 ? (
      <ul class="posts">
        {posts.map((p) => (
          <li class="post">
            <a class="post-link" href={`/blog/${p.id}`}>
              <span class="ptitle">{p.data.title}</span>
              <time class="pdate mono" datetime={p.data.pubDate.toISOString()}>{fmt(p.data.pubDate)}</time>
            </a>
            {p.data.description && <p class="pdesc">{p.data.description}</p>}
          </li>
        ))}
      </ul>
    ) : (
      <div class="soon">
        <p class="soon-line mono"><span class="dot" aria-hidden="true"></span>status: migrating a few good articles over</p>
        <p class="soon-sub">Hold tight — they'll land here soon. Find me on the links below in the meantime.</p>
      </div>
    )}
  </main>
</Base>

<style>
  .page-head {
    padding-top: clamp(2.5rem, 2rem + 4vw, 5rem);
    padding-bottom: clamp(1rem, 0.5rem + 2vw, 2rem);
  }
  .back { display: inline-block; font-size: var(--step--1); color: var(--fg-soft); text-decoration: none; margin-bottom: 1.6rem; }
  .back:hover { color: var(--accent); }
  h1 { font-size: var(--step-2); font-weight: 500; letter-spacing: -0.03em; }
  .posts { list-style: none; display: grid; gap: 1.8rem; padding-block: 1.5rem 3rem; }
  .post-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    text-decoration: none;
    color: var(--fg);
  }
  .ptitle { font-family: var(--font-display); font-size: var(--step-1); font-weight: 600; }
  .post-link:hover .ptitle { color: var(--accent); }
  .pdate { font-size: var(--step--1); color: var(--fg-faint); white-space: nowrap; }
  .pdesc { color: var(--fg-soft); margin-top: 0.4rem; max-width: var(--measure); }

  .soon { padding-block: 1.5rem 3rem; }
  .soon-line { font-size: var(--step-0); color: var(--fg); }
  .soon-sub { font-size: var(--step-0); color: var(--fg-soft); margin-top: 0.8rem; max-width: 52ch; line-height: 1.7; }
  .dot {
    display: inline-block;
    position: relative;
    width: 7px;
    height: 7px;
    margin-right: 0.6em;
    border-radius: 50%;
    background: var(--accent);
    vertical-align: 0.05em;
  }
  .dot::after { content: ''; position: absolute; inset: 0; border-radius: 50%; background: var(--accent); }
  @media (prefers-reduced-motion: no-preference) {
    .dot::after { animation: ping 1.9s cubic-bezier(0, 0, 0.2, 1) infinite; }
  }
  @keyframes ping { 75%, 100% { transform: scale(2.6); opacity: 0; } }
</style>
