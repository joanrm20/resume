---
import Base from '../layouts/Base.astro'
import { resume, emphasize } from '../lib/resume'

const b = resume.basics
const currently = 'core product · Employees & Organizations @ Personio'

const primary = [
  { label: 'experience', href: '/experience' },
  { label: 'writing', href: '/blog' },
  { label: 'résumé', href: '/jose_ramirez_cv.pdf' },
]
---

<Base>
  <main class="home wrap">
    <p class="shell mono" aria-hidden="true">
      <span class="usr">jose@joanrm20</span> <span class="pth">~</span> <span class="pct">%</span> <span id="cmd-whoami">whoami</span><span class="caret"></span>
    </p>

    <h1 class="name">{b.name}</h1>
    <p class="role">{b.label}</p>

    {b.summary && <p class="about" set:html={emphasize(b.summary)} />}

    <p class="currently mono"><span class="ckey">// currently</span> → {currently}</p>

    <nav class="nav" aria-label="Explore">
      {primary.map((l) => (
        <a class="primary" href={l.href} {...(l.href.endsWith('.pdf') ? { target: '_blank', rel: 'noopener' } : {})}>{l.label}</a>
      ))}
    </nav>
  </main>
</Base>

<script>
  function initHome() {
    const who = document.getElementById('cmd-whoami')
    if (who && !matchMedia('(prefers-reduced-motion: reduce)').matches && !who.dataset.typed) {
      who.dataset.typed = '1'
      const text = 'whoami'
      who.textContent = ''
      let i = 0
      const step = () => {
        who.textContent = text.slice(0, ++i)
        if (i < text.length) setTimeout(step, 75)
      }
      setTimeout(step, 280)
    }
  }
  document.addEventListener('astro:page-load', initHome)
</script>

<style>
  .home {
    padding-top: clamp(4rem, 3rem + 8vw, 9rem);
    padding-bottom: 1rem;
  }

  .shell { font-size: var(--step--1); color: var(--fg-faint); }
  .usr { color: var(--accent); }
  .pth { color: var(--fg-soft); }
  .pct { color: var(--fg-faint); }
  .caret {
    display: inline-block;
    width: 0.55em;
    height: 1.05em;
    margin-left: 0.25em;
    background: var(--accent);
    vertical-align: -0.16em;
    animation: blink 1.15s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .caret { animation: none; } }

  .name {
    font-size: var(--step-2);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin-top: 1.7rem;
  }
  .role {
    font-size: var(--step-0);
    color: var(--fg-soft);
    margin-top: 0.35rem;
  }
  .about {
    max-width: 56ch;
    font-size: var(--step-0);
    line-height: 1.8;
    color: var(--fg-soft);
    margin-top: 2.8rem;
  }
  .currently { font-size: var(--step--1); color: var(--fg-faint); margin-top: 1.9rem; }
  .currently .ckey { color: var(--fg-soft); }
  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.7rem;
    margin-top: 2.8rem;
  }
  .nav .primary {
    font-size: var(--step-0);
    color: var(--fg);
    text-decoration: none;
  }
  .nav .primary:hover { color: var(--accent); }
</style>
